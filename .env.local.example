# Supabase (create project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Passwords: run `npm run hash-password "yourpassword"` then base64 the printed hash:
#   node -e "console.log(Buffer.from('PASTE_HASH_HERE').toString('base64'))"
# Or set FAMILY_PASSWORD_HASH / ADMIN_PASSWORD_HASH only if your env loader allows $ in values.
FAMILY_PASSWORD_HASH_B64=
ADMIN_PASSWORD_HASH_B64=

# Random string for signing session cookies (e.g. openssl rand -hex 32)
SESSION_SECRET=your-session-secret-at-least-32-chars
