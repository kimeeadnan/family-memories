# Supabase (create project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Easiest on Vercel (no bcrypt): plain passwords (optional; use strong values in production)
FAMILY_PASSWORD=
ADMIN_PASSWORD=
# Or bcrypt: run `npm run hash-password "pw"` then base64 the hash for B64 vars below.
FAMILY_PASSWORD_HASH_B64=
ADMIN_PASSWORD_HASH_B64=

# Random string for signing session cookies (e.g. openssl rand -hex 32)
SESSION_SECRET=your-session-secret-at-least-32-chars

# Optional: gallery background music after login (comma-separated paths or HTTPS URLs to MP3s)
# Default files if unset: public/audio/family-1.mp3 and public/audio/family-2.mp3
# NEXT_PUBLIC_GALLERY_AUDIO_TRACKS=/audio/family-1.mp3,/audio/family-2.mp3
